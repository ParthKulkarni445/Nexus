# ===== CONFIG =====
SERVER = nexus@172.30.8.178
APP_DIR = /home/nexus/app

# ===== BUILD =====
build:
	npm run build

# ===== DEPLOY =====
deploy: build
	# Ensure directories exist
	ssh $(SERVER) "mkdir -p $(APP_DIR)/.next"

	# Clean old static (prevents stale UI bugs)
	ssh $(SERVER) "rm -rf $(APP_DIR)/.next/static"

	# Copy standalone SERVER FILES (flattened correctly)
	scp -r .next/standalone/* $(SERVER):$(APP_DIR)

	# Copy static assets (correct path)
	scp -r .next/static $(SERVER):$(APP_DIR)/.next

	# Copy public assets
	scp -r public $(SERVER):$(APP_DIR) || true

	# Restart app cleanly on fixed port
	ssh $(SERVER) "pm2 delete nexus-app || true"
	ssh $(SERVER) "cd $(APP_DIR) pm2 start server.js --name nexus-app"
	ssh $(SERVER) "pm2 save"

# ===== FIRST TIME SETUP =====
setup:
	ssh $(SERVER) "mkdir -p $(APP_DIR)/.next"

	scp -r .next/standalone/* $(SERVER):$(APP_DIR)
	scp -r .next/static $(SERVER):$(APP_DIR)/.next
	scp -r public $(SERVER):$(APP_DIR) || true
	scp -r prisma $(SERVER):$(APP_DIR)

# ===== LOGS =====
logs:
	ssh $(SERVER) "pm2 logs nexus-app"

# ===== STATUS =====
status:
	ssh $(SERVER) "pm2 status"