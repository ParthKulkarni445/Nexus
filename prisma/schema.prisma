generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                    String                       @unique @db.VarChar(255)
  name                     String                       @db.VarChar(255)
  role                     UserRole
  coordinatorType          CoordinatorType?             @map("coordinator_type")
  authProvider             String?                      @map("auth_provider") @db.VarChar(100)
  authSubject              String?                      @map("auth_subject") @db.VarChar(255)
  profileMeta              Json?                        @map("profile_meta")
  isActive                 Boolean                      @default(true) @map("is_active")
  createdAt                DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                     @default(now()) @map("updated_at") @db.Timestamptz(6)
  phone                    String?                      @db.VarChar(30)
  auditLogs                AuditLog[]
  blogVotes                BlogVote[]
  approvedBlogs            Blog[]                       @relation("BlogApprover")
  authoredBlogs            Blog[]                       @relation("BlogAuthor")
  createdCompanies         Company[]                    @relation("CompanyCreator")
  updatedCompanies         Company[]                    @relation("CompanyUpdater")
  assignmentHistoryChanged CompanyAssignmentHistory[]   @relation("AssignmentHistoryChangedBy")
  assignmentHistoryFrom    CompanyAssignmentHistory[]   @relation("AssignmentHistoryFrom")
  assignmentHistoryTo      CompanyAssignmentHistory[]   @relation("AssignmentHistoryTo")
  assignmentAssigner       CompanyAssignment[]          @relation("AssignmentAssigner")
  assignmentAssignee       CompanyAssignment[]          @relation("AssignmentAssignee")
  createdCompanyDomains    CompanyDomain[]              @relation("CompanyDomainCreator")
  seasonOwnerships         CompanySeasonCycle[]         @relation("SeasonCycleOwner")
  seasonCycleUpdates       CompanySeasonCycle[]         @relation("SeasonCycleUpdatedBy")
  seasonStatusChanges      CompanySeasonStatusHistory[]
  uploadedStudentEntries   CompanySeasonStudentEntry[]
  interactionsCreated      ContactInteraction[]
  createdDrives            Drive[]
  templateVersionsCreated  EmailTemplateVersion[]
  approvedTemplates        EmailTemplate[]              @relation("TemplateApprover")
  createdTemplates         EmailTemplate[]              @relation("TemplateCreator")
  uploadedMailAssets       MailAsset[]                  @relation("MailAssetUploader")
  requestedMailRequests    MailRequest[]                @relation("MailRequestRequester")
  reviewedMailRequests     MailRequest[]                @relation("MailRequestReviewer")
  notifications            Notification[]
  placements               Placement[]
  createdSeasons           RecruitmentSeason[]
  createdSchedules         Schedule[]                   @relation("ScheduleCreator")
  updatedSchedules         Schedule[]                   @relation("ScheduleUpdater")
  follows                  StudentCompanyFollow[]
  studentDataConsent       StudentDataConsent?
  grantedPermissions       UserPermission[]             @relation("PermissionGrants")
  permissions              UserPermission[]             @relation("UserPermissions")

  @@map("users")
}

model UserPermission {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  permissionKey String   @map("permission_key") @db.VarChar(100)
  isAllowed     Boolean  @map("is_allowed")
  grantedBy     String?  @map("granted_by") @db.Uuid
  grantedAt     DateTime @default(now()) @map("granted_at") @db.Timestamptz(6)
  grantedByUser User?    @relation("PermissionGrants", fields: [grantedBy], references: [id])
  user          User     @relation("UserPermissions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, permissionKey], map: "user_permissions_user_key_idx")
  @@map("user_permissions")
}

model Company {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String                 @db.VarChar(255)
  slug         String                 @unique @db.VarChar(255)
  domain       String?                @db.VarChar(255)
  industry     String?                @db.VarChar(100)
  website      String?                @db.VarChar(500)
  priority     Int?
  notes        String?
  createdBy    String?                @map("created_by") @db.Uuid
  createdAt    DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy    String?                @map("updated_by") @db.Uuid
  updatedField String?                @map("updated_field") @db.VarChar(100)
  blogs        Blog[]
  creator      User?                  @relation("CompanyCreator", fields: [createdBy], references: [id])
  updater      User?                  @relation("CompanyUpdater", fields: [updatedBy], references: [id])
  contacts     CompanyContact[]
  domains      CompanyDomain[]
  seasonCycles CompanySeasonCycle[]
  interactions ContactInteraction[]
  drives       Drive[]
  emailThreads EmailThreadMapping[]
  emails       Email[]
  mailRequests MailRequest[]
  placements   Placement[]
  schedules    Schedule[]
  follows      StudentCompanyFollow[]

  @@index([name])
  @@index([industry])
  @@index([createdAt])
  @@map("companies")
}

model CompanyContact {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId              String    @map("company_id") @db.Uuid
  name                   String    @db.VarChar(255)
  designation            String?   @db.VarChar(255)
  emails                 String[]  @default([])
  phones                 String[]  @default([])
  preferredContactMethod String?   @map("preferred_contact_method") @db.VarChar(50)
  notes                  String?
  lastContactedAt        DateTime? @map("last_contacted_at") @db.Timestamptz(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt], map: "company_contacts_company_created_idx")
  @@map("company_contacts")
}

model CompanyAssignment {
  id             String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemType       AssignmentItemType         @map("item_type")
  itemId         String                     @map("item_id") @db.Uuid
  assigneeUserId String                     @map("assignee_user_id") @db.Uuid
  assignedBy     String?                    @map("assigned_by") @db.Uuid
  notes          String?
  isActive       Boolean                    @default(true) @map("is_active")
  assignedAt     DateTime                   @default(now()) @map("assigned_at") @db.Timestamptz(6)
  updatedAt      DateTime                   @default(now()) @map("updated_at") @db.Timestamptz(6)
  history        CompanyAssignmentHistory[]
  assignerUser   User?                      @relation("AssignmentAssigner", fields: [assignedBy], references: [id])
  assigneeUser   User                       @relation("AssignmentAssignee", fields: [assigneeUserId], references: [id])

  @@index([itemType, itemId, isActive, assignedAt], map: "company_assignments_item_lookup_idx")
  @@index([assigneeUserId, isActive, assignedAt], map: "company_assignments_assignee_active_idx")
  @@map("company_assignments")
}

model CompanyAssignmentHistory {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assignmentId  String            @map("assignment_id") @db.Uuid
  fromUserId    String?           @map("from_user_id") @db.Uuid
  toUserId      String?           @map("to_user_id") @db.Uuid
  changedBy     String            @map("changed_by") @db.Uuid
  reason        String?
  changedAt     DateTime          @default(now()) @map("changed_at") @db.Timestamptz(6)
  assignment    CompanyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  changedByUser User              @relation("AssignmentHistoryChangedBy", fields: [changedBy], references: [id])
  fromUser      User?             @relation("AssignmentHistoryFrom", fields: [fromUserId], references: [id])
  toUser        User?             @relation("AssignmentHistoryTo", fields: [toUserId], references: [id])

  @@index([assignmentId, changedAt], map: "company_assignment_history_assignment_changed_at_idx")
  @@map("company_assignment_history")
}

model RecruitmentSeason {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String               @db.VarChar(255)
  seasonType    SeasonType           @map("season_type")
  academicYear  String               @map("academic_year") @db.VarChar(20)
  startDate     DateTime?            @map("start_date") @db.Date
  endDate       DateTime?            @map("end_date") @db.Date
  isActive      Boolean              @default(true) @map("is_active")
  createdBy     String?              @map("created_by") @db.Uuid
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  companyCycles CompanySeasonCycle[]
  placements    Placement[]
  creator       User?                @relation(fields: [createdBy], references: [id])

  @@index([seasonType, academicYear, isActive], map: "recruitment_seasons_type_year_active_idx")
  @@map("recruitment_seasons")
}

model CompanySeasonCycle {
  id              String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String                       @map("company_id") @db.Uuid
  seasonId        String                       @map("season_id") @db.Uuid
  status          SeasonContactStatus
  lastContactedAt DateTime?                    @map("last_contacted_at") @db.Timestamptz(6)
  ownerUserId     String?                      @map("owner_user_id") @db.Uuid
  nextFollowUpAt  DateTime?                    @map("next_follow_up_at") @db.Timestamptz(6)
  notes           String?
  createdAt       DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                     @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy       String?                      @map("updated_by") @db.Uuid
  updatedField    String?                      @map("updated_field") @db.VarChar(100)
  company         Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner           User?                        @relation("SeasonCycleOwner", fields: [ownerUserId], references: [id])
  season          RecruitmentSeason            @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  updater         User?                        @relation("SeasonCycleUpdatedBy", fields: [updatedBy], references: [id])
  statusHistory   CompanySeasonStatusHistory[]
  studentEntries  CompanySeasonStudentEntry[]
  interactions    ContactInteraction[]
  drives          Drive[]
  emails          Email[]
  mailRequests    MailRequest[]

  @@unique([companyId, seasonId])
  @@index([seasonId, status, updatedAt], map: "company_season_cycles_season_status_updated_idx")
  @@index([seasonId, ownerUserId, updatedAt], map: "company_season_cycles_season_owner_updated_idx")
  @@index([companyId, updatedAt], map: "company_season_cycles_company_updated_idx")
  @@index([ownerUserId, updatedAt], map: "company_season_cycles_owner_updated_idx")
  @@map("company_season_cycles")
}

model CompanySeasonStudentEntry {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companySeasonCycleId String             @map("company_season_cycle_id") @db.Uuid
  entryNumber          String             @map("entry_number") @db.VarChar(20)
  uploadedBy           String?            @map("uploaded_by") @db.Uuid
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  driveId              String?            @map("drive_id") @db.Uuid
  companySeasonCycle   CompanySeasonCycle @relation(fields: [companySeasonCycleId], references: [id], onDelete: Cascade, map: "company_season_student_entries_cycle_fkey")
  drive                Drive?             @relation(fields: [driveId], references: [id], onDelete: Cascade, map: "company_season_student_entries_drive_fkey")
  uploader             User?              @relation(fields: [uploadedBy], references: [id])

  @@unique([companySeasonCycleId, driveId, entryNumber], map: "company_season_student_entries_cycle_drive_entry_key")
  @@index([companySeasonCycleId], map: "company_season_student_entries_cycle_idx")
  @@index([driveId], map: "company_season_student_entries_drive_idx")
  @@index([entryNumber], map: "company_season_student_entries_entry_idx")
  @@map("company_season_student_entries")
}

model CompanySeasonStatusHistory {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companySeasonCycleId String               @map("company_season_cycle_id") @db.Uuid
  fromStatus           SeasonContactStatus? @map("from_status")
  toStatus             SeasonContactStatus  @map("to_status")
  changedBy            String               @map("changed_by") @db.Uuid
  changeNote           String?              @map("change_note")
  changedAt            DateTime             @default(now()) @map("changed_at") @db.Timestamptz(6)
  changer              User                 @relation(fields: [changedBy], references: [id])
  companySeasonCycle   CompanySeasonCycle   @relation(fields: [companySeasonCycleId], references: [id], onDelete: Cascade)

  @@index([companySeasonCycleId, changedAt], map: "company_season_status_history_cycle_changed_idx")
  @@map("company_season_status_history")
}

model ContactInteraction {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId            String              @map("company_id") @db.Uuid
  contactId            String?             @map("contact_id") @db.Uuid
  companySeasonCycleId String?             @map("company_season_cycle_id") @db.Uuid
  interactionType      String              @map("interaction_type") @db.VarChar(50)
  outcome              String?             @db.VarChar(255)
  summary              String?
  nextFollowUpAt       DateTime?           @map("next_follow_up_at") @db.Timestamptz(6)
  createdBy            String              @map("created_by") @db.Uuid
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  company              Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companySeasonCycle   CompanySeasonCycle? @relation(fields: [companySeasonCycleId], references: [id], onDelete: Cascade)
  creator              User                @relation(fields: [createdBy], references: [id])

  @@index([companyId, createdAt], map: "contact_interactions_company_created_idx")
  @@index([companySeasonCycleId, createdAt], map: "contact_interactions_cycle_created_idx")
  @@map("contact_interactions")
}

model Drive {
  id                   String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId            String                      @map("company_id") @db.Uuid
  companySeasonCycleId String                      @map("company_season_cycle_id") @db.Uuid
  title                String                      @db.VarChar(255)
  notes                String?
  createdBy            String?                     @map("created_by") @db.Uuid
  createdAt            DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                    @default(now()) @map("updated_at") @db.Timestamptz(6)
  jobDescriptionDocUrl String?                     @map("job_description_doc_url") @db.VarChar(500)
  jobDescriptionText   String?                     @map("job_description_text")
  notificationFormUrl  String?                     @map("notification_form_url") @db.VarChar(500)
  compensationAmount   Decimal?                    @map("compensation_amount") @db.Decimal(12, 2)
  studentEntries       CompanySeasonStudentEntry[]
  company              Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companySeasonCycle   CompanySeasonCycle          @relation(fields: [companySeasonCycleId], references: [id], onDelete: Cascade)
  creator              User?                       @relation(fields: [createdBy], references: [id])
  emails               Email[]
  placements           Placement[]
  eligibilityRules     RoleEligibility[]

  @@index([companyId, createdAt], map: "drives_company_created_idx")
  @@index([companySeasonCycleId, createdAt], map: "drives_cycle_created_idx")
  @@index([title])
  @@map("drives")
}

model RoleEligibility {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  driveId              String   @map("drive_id") @db.Uuid
  branches             String[] @default([])
  includeMinorBranches Boolean  @default(false) @map("include_minor_branches")
  minCgpa              Decimal? @map("min_cgpa") @db.Decimal(4, 2)
  allowsBacklogs       Boolean  @default(false) @map("allows_backlogs")
  notes                String?
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  drive                Drive    @relation(fields: [driveId], references: [id], onDelete: Cascade)

  @@index([driveId], map: "role_eligibility_drive_idx")
  @@map("role_eligibility")
}

model StudentCompanyFollow {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, companyId])
  @@index([companyId], map: "student_company_follows_company_idx")
  @@map("student_company_follows")
}

model Email {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  direction            EmailDirection
  messageId            String              @unique @map("message_id") @db.VarChar(500)
  mailRequestId        String?             @map("mail_request_id") @db.Uuid
  templateId           String?             @map("template_id") @db.Uuid
  templateVersion      Int?                @map("template_version")
  companyId            String?             @map("company_id") @db.Uuid
  driveId              String?             @map("drive_id") @db.Uuid
  companySeasonCycleId String?             @map("company_season_cycle_id") @db.Uuid
  fromEmail            String              @map("from_email") @db.VarChar(255)
  toEmails             String[]            @default([]) @map("to_emails")
  ccEmails             String[]            @default([]) @map("cc_emails")
  subject              String              @db.VarChar(500)
  textBody             String?             @map("text_body")
  htmlBody             String?             @map("html_body")
  inReplyTo            String?             @map("in_reply_to") @db.VarChar(500)
  references           String[]            @default([])
  threadId             String?             @map("thread_id") @db.VarChar(255)
  headers              Json?
  classification       Json?
  providerStatus       String?             @map("provider_status") @db.VarChar(100)
  providerEventAt      DateTime?           @map("provider_event_at") @db.Timestamptz(6)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  attachments          EmailAttachment[]
  company              Company?            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companySeasonCycle   CompanySeasonCycle? @relation(fields: [companySeasonCycleId], references: [id], onDelete: Cascade)
  drive                Drive?              @relation(fields: [driveId], references: [id], onDelete: Cascade)
  mailRequest          MailRequest?        @relation(fields: [mailRequestId], references: [id], onDelete: Cascade)
  template             EmailTemplate?      @relation(fields: [templateId], references: [id])

  @@index([companyId, createdAt], map: "emails_company_created_idx")
  @@map("emails")
}

model EmailThreadMapping {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  threadId       String   @unique @map("thread_id") @db.VarChar(255)
  companyId      String   @map("company_id") @db.Uuid
  source         String   @db.VarChar(50)
  confidence     String?  @db.VarChar(50)
  lastResolvedAt DateTime @default(now()) @map("last_resolved_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, updatedAt], map: "email_thread_mappings_company_updated_idx")
  @@map("email_thread_mappings")
}

model EmailAttachment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  emailId     String   @map("email_id") @db.Uuid
  fileName    String   @map("file_name") @db.VarChar(255)
  mimeType    String?  @map("mime_type") @db.VarChar(255)
  sizeBytes   Int?     @map("size_bytes")
  storagePath String   @map("storage_path") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@map("email_attachments")
}

model MailAsset {
  id               String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileName         String                    @map("file_name") @db.VarChar(255)
  mimeType         String?                   @map("mime_type") @db.VarChar(255)
  sizeBytes        Int?                      @map("size_bytes")
  storagePath      String                    @unique @map("storage_path") @db.VarChar(500)
  publicUrl        String                    @map("public_url") @db.VarChar(500)
  uploadedBy       String?                   @map("uploaded_by") @db.Uuid
  createdAt        DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  templateLinks    EmailTemplateAttachment[]
  uploader         User?                     @relation("MailAssetUploader", fields: [uploadedBy], references: [id])
  mailRequestLinks MailRequestAttachment[]

  @@index([createdAt], map: "mail_assets_created_idx")
  @@map("mail_assets")
}

model EmailTemplateAttachment {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId  String        @map("template_id") @db.Uuid
  mailAssetId String        @map("mail_asset_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  mailAsset   MailAsset     @relation(fields: [mailAssetId], references: [id])
  template    EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, mailAssetId], map: "email_template_attachments_unique")
  @@index([templateId, createdAt], map: "email_template_attachments_template_created_idx")
  @@map("email_template_attachments")
}

model MailRequestAttachment {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mailRequestId String      @map("mail_request_id") @db.Uuid
  mailAssetId   String      @map("mail_asset_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  mailAsset     MailAsset   @relation(fields: [mailAssetId], references: [id])
  mailRequest   MailRequest @relation(fields: [mailRequestId], references: [id], onDelete: Cascade)

  @@unique([mailRequestId, mailAssetId], map: "mail_request_attachments_unique")
  @@index([mailRequestId, createdAt], map: "mail_request_attachments_request_created_idx")
  @@map("mail_request_attachments")
}

model CompanyDomain {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  domain     String   @db.VarChar(255)
  confidence String?  @db.VarChar(50)
  createdBy  String?  @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator    User?    @relation("CompanyDomainCreator", fields: [createdBy], references: [id])

  @@unique([companyId, domain])
  @@map("company_domains")
}

model EmailTemplate {
  id           String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String                    @db.VarChar(255)
  slug         String                    @unique @db.VarChar(255)
  subject      String                    @db.VarChar(500)
  bodyHtml     String                    @map("body_html")
  bodyText     String?                   @map("body_text")
  variables    String[]                  @default([])
  sendPolicy   Json?                     @map("send_policy")
  status       TemplateStatus
  createdBy    String?                   @map("created_by") @db.Uuid
  approvedBy   String?                   @map("approved_by") @db.Uuid
  createdAt    DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                  @default(now()) @map("updated_at") @db.Timestamptz(6)
  attachments  EmailTemplateAttachment[]
  versions     EmailTemplateVersion[]
  approver     User?                     @relation("TemplateApprover", fields: [approvedBy], references: [id])
  creator      User?                     @relation("TemplateCreator", fields: [createdBy], references: [id])
  emails       Email[]
  mailRequests MailRequest[]

  @@index([status, updatedAt], map: "email_templates_status_updated_idx")
  @@map("email_templates")
}

model EmailTemplateVersion {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId String        @map("template_id") @db.Uuid
  version    Int
  subject    String        @db.VarChar(500)
  bodyHtml   String        @map("body_html")
  bodyText   String?       @map("body_text")
  variables  String[]      @default([])
  createdBy  String?       @map("created_by") @db.Uuid
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  creator    User?         @relation(fields: [createdBy], references: [id])
  template   EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@map("email_template_versions")
}

model MailRequest {
  id                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId            String?                 @map("company_id") @db.Uuid
  requestedBy          String                  @map("requested_by") @db.Uuid
  companySeasonCycleId String?                 @map("company_season_cycle_id") @db.Uuid
  requestType          MailRequestType         @map("request_type")
  templateId           String?                 @map("template_id") @db.Uuid
  templateVersion      Int?                    @map("template_version")
  customSubject        String?                 @map("custom_subject") @db.VarChar(500)
  customBody           String?                 @map("custom_body")
  recipientFilter      Json?                   @map("recipient_filter")
  previewPayload       Json?                   @map("preview_payload")
  status               MailRequestStatus
  urgency              Int?
  reviewedBy           String?                 @map("reviewed_by") @db.Uuid
  reviewNote           String?                 @map("review_note")
  sendAt               DateTime?               @map("send_at") @db.Timestamptz(6)
  sentAt               DateTime?               @map("sent_at") @db.Timestamptz(6)
  createdAt            DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                @default(now()) @map("updated_at") @db.Timestamptz(6)
  emails               Email[]
  attachments          MailRequestAttachment[]
  company              Company?                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companySeasonCycle   CompanySeasonCycle?     @relation(fields: [companySeasonCycleId], references: [id], onDelete: Cascade)
  requester            User                    @relation("MailRequestRequester", fields: [requestedBy], references: [id])
  reviewer             User?                   @relation("MailRequestReviewer", fields: [reviewedBy], references: [id])
  template             EmailTemplate?          @relation(fields: [templateId], references: [id])

  @@index([status, createdAt], map: "mail_requests_status_created_idx")
  @@index([sendAt])
  @@index([requestedBy, createdAt], map: "mail_requests_requested_by_created_idx")
  @@map("mail_requests")
}

model Blog {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId         String               @map("author_id") @db.Uuid
  companyId        String               @map("company_id") @db.Uuid
  title            String               @db.VarChar(500)
  body             String
  tags             String[]             @default([])
  isAiAssisted     Boolean?             @default(false) @map("is_ai_assisted")
  moderationStatus BlogModerationStatus @map("moderation_status")
  moderationNote   String?              @map("moderation_note")
  approvedBy       String?              @map("approved_by") @db.Uuid
  approvedAt       DateTime?            @map("approved_at") @db.Timestamptz(6)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  votes            BlogVote[]
  approver         User?                @relation("BlogApprover", fields: [approvedBy], references: [id])
  author           User                 @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  company          Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt], map: "blogs_company_created_idx")
  @@index([moderationStatus, createdAt], map: "blogs_moderation_created_idx")
  @@map("blogs")
}

model BlogVote {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blogId    String       @map("blog_id") @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  voteType  BlogVoteType @map("vote_type")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  blog      Blog         @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([blogId, userId], map: "blog_votes_blog_user_key")
  @@index([blogId, voteType], map: "blog_votes_blog_vote_type_idx")
  @@index([userId, createdAt], map: "blog_votes_user_created_idx")
  @@map("blog_votes")
}

model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String    @db.VarChar(100)
  title     String    @db.VarChar(255)
  body      String?
  payload   Json?
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt], map: "notifications_user_read_created_idx")
  @@map("notifications")
}

model Schedule {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String         @map("company_id") @db.Uuid
  title       String         @db.VarChar(255)
  description String?
  startTime   DateTime       @map("start_time") @db.Timestamptz(6)
  endTime     DateTime       @map("end_time") @db.Timestamptz(6)
  status      ScheduleStatus @default(scheduled)
  createdBy   String?        @map("created_by") @db.Uuid
  updatedBy   String?        @map("updated_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator     User?          @relation("ScheduleCreator", fields: [createdBy], references: [id])
  updater     User?          @relation("ScheduleUpdater", fields: [updatedBy], references: [id])

  @@index([companyId, startTime], map: "schedules_company_start_idx")
  @@index([status, startTime], map: "schedules_status_start_idx")
  @@map("schedules")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String   @db.VarChar(255)
  targetType String?  @map("target_type") @db.VarChar(100)
  targetId   String?  @map("target_id") @db.Uuid
  meta       Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(100)
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([createdAt], map: "audit_logs_created_idx")
  @@index([actorId, createdAt], map: "audit_logs_actor_created_idx")
  @@map("audit_logs")
}

model Placement {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId        String            @map("student_id") @db.Uuid
  companyId        String            @map("company_id") @db.Uuid
  seasonId         String            @map("season_id") @db.Uuid
  driveId          String?           @map("drive_id") @db.Uuid
  role             String            @db.VarChar(255)
  packageType      String            @map("package_type") @db.VarChar(50)
  packageAmount    Decimal           @map("package_amount") @db.Decimal(12, 2)
  packageFrequency String?           @map("package_frequency") @db.VarChar(20)
  currency         String            @default("INR") @db.VarChar(10)
  selectionDate    DateTime?         @map("selection_date") @db.Date
  placementStatus  String            @default("accepted") @map("placement_status") @db.VarChar(50)
  source           String?           @db.VarChar(100)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  drive            Drive?            @relation(fields: [driveId], references: [id])
  season           RecruitmentSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  student          User              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([seasonId, companyId], map: "placements_season_company_idx")
  @@index([studentId, seasonId], map: "placements_student_season_idx")
  @@index([packageAmount])
  @@map("placements")
}

model StudentDataConsent {
  studentId                String   @id @map("student_id") @db.Uuid
  allowPublicPlacementData Boolean  @default(false) @map("allow_public_placement_data")
  updatedAt                DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
